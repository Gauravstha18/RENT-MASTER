rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(data) {
      return isSignedIn() && data.ownerId == request.auth.uid;
    }

    function isIncomingOwner() {
      return isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    // houses collection rules
    match /houses/{houseId} {
      allow read, delete: if isOwner(resource.data);
      allow create: if isIncomingOwner() && 
                    request.resource.data.name is string && 
                    request.resource.data.name.size() > 0 && 
                    request.resource.data.name.size() <= 200;
      allow update: if isOwner(resource.data) && isIncomingOwner();
    }

    // rooms collection rules
    match /rooms/{roomId} {
      allow read, delete: if isOwner(resource.data);
      allow create: if isIncomingOwner() && 
                    request.resource.data.roomNumber is string && 
                    request.resource.data.roomNumber.size() > 0 && 
                    request.resource.data.roomNumber.size() <= 50;
      allow update: if isOwner(resource.data) && isIncomingOwner();
    }

    // tenants collection rules
    match /tenants/{tenantId} {
      allow read, delete: if isOwner(resource.data);
      allow create: if isIncomingOwner() && 
                    request.resource.data.name is string && 
                    request.resource.data.name.size() > 0 && 
                    request.resource.data.name.size() <= 200;
      allow update: if isOwner(resource.data) && isIncomingOwner();
    }

    // payments collection rules
    match /payments/{paymentId} {
      allow read, delete: if isOwner(resource.data);
      allow create: if isIncomingOwner() && 
                    request.resource.data.month is string && 
                    request.resource.data.month.size() > 0 && 
                    request.resource.data.month.size() <= 50;
      allow update: if isOwner(resource.data) && isIncomingOwner();
    }
  }
}
